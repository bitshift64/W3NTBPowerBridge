<Window x:Class="W3NTBPowerBridge.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="720"
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}">
  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>
    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
      <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
    </Style>
    <Style TargetType="Button">
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
      <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
    </Style>
  </Window.Resources>
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="170" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" Grid.Column="0" Text="ACLog host" Margin="0,0,10,10" VerticalAlignment="Center" />
      <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding AcLogHost}" Margin="0,0,0,10" />
      <TextBlock Grid.Row="1" Grid.Column="0" Text="ACLog port" Margin="0,0,10,10" VerticalAlignment="Center" />
      <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding AcLogPort}" Margin="0,0,0,10" />
      <TextBlock Grid.Row="2" Grid.Column="0" Text="wfview host" Margin="0,0,10,10" VerticalAlignment="Center" />
      <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding WfviewHost}" Margin="0,0,0,10" />
      <TextBlock Grid.Row="3" Grid.Column="0" Text="wfview port" Margin="0,0,10,10" VerticalAlignment="Center" />
      <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding WfviewPort}" Margin="0,0,0,10" />
      <TextBlock Grid.Row="4" Grid.Column="0" Text="wfview.exe path" Margin="0,0,10,10" VerticalAlignment="Center" />
      <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding WfviewPath}" Margin="0,0,0,10" />
      <TextBlock Grid.Row="5" Grid.Column="0" Text="ACLog.exe path" Margin="0,0,10,10" VerticalAlignment="Center" />
      <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding AcLogPath}" Margin="0,0,0,10" />
      <CheckBox Grid.Row="6" Grid.Column="1" Content="Connect automatically on startup" IsChecked="{Binding AutoConnectOnStartup}" Margin="0,0,0,10" />
      <CheckBox Grid.Row="7" Grid.Column="1" Content="Launch wfview automatically" IsChecked="{Binding AutoLaunchWfview}" Margin="0,0,0,10" />
      <CheckBox Grid.Row="8" Grid.Column="1" Content="Launch ACLog automatically" IsChecked="{Binding AutoLaunchAcLog}" Margin="0,0,0,10" />
      <CheckBox Grid.Row="9" Grid.Column="1" Content="Sync RF power to ACLog power field" IsChecked="{Binding SyncRfPowerToAcLog}" Margin="0,0,0,10" />
      <TextBlock Grid.Row="10" Grid.Column="0" Text="Radio max watts" Margin="0,0,10,10" VerticalAlignment="Center" />
      <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding RadioMaxPowerWatts}" Margin="0,0,0,10" />
      <Separator Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,16" />
      <CheckBox Grid.Row="12" Grid.Column="1" Content="Start full station sequence on startup" IsChecked="{Binding AutoStartStationOnStartup}" Margin="0,0,0,10" />
      <CheckBox Grid.Row="13" Grid.Column="1" Content="Enable Shelly station power" IsChecked="{Binding ShellyEnabled}" Margin="0,0,0,10" />
      <TextBlock Grid.Row="14" Grid.Column="0" Text="Shelly host" Margin="0,0,10,10" VerticalAlignment="Center" />
      <TextBox Grid.Row="14" Grid.Column="1" Text="{Binding ShellyHost}" Margin="0,0,0,10" />
      <TextBlock Grid.Row="15" Grid.Column="0" Text="Shelly port / switch ID" Margin="0,0,10,10" VerticalAlignment="Center" />
      <StackPanel Grid.Row="15" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
        <TextBox Text="{Binding ShellyPort}" Width="90" Margin="0,0,10,0" />
        <TextBox Text="{Binding ShellySwitchId}" Width="90" />
      </StackPanel>
      <TextBlock Grid.Row="16" Grid.Column="0" Text="Off threshold watts" Margin="0,0,10,10" VerticalAlignment="Center" />
      <TextBox Grid.Row="16" Grid.Column="1" Text="{Binding StationOffPowerThresholdWatts}" Margin="0,0,0,10" />
      <TextBlock Grid.Row="17" Grid.Column="0" Text="Power-on delay seconds" Margin="0,0,10,10" VerticalAlignment="Center" />
      <TextBox Grid.Row="17" Grid.Column="1" Text="{Binding StationPowerOnDelaySeconds}" Margin="0,0,0,10" />
      <Separator Grid.Row="18" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,16" />
      <TextBlock Grid.Row="19" Grid.Column="0" Text="Main screen" FontWeight="SemiBold" Margin="0,0,10,10" VerticalAlignment="Center" />
      <CheckBox Grid.Row="19" Grid.Column="1" Content="Show event log" IsChecked="{Binding ShowEventLog}" Margin="0,0,0,10" />
      <CheckBox Grid.Row="20" Grid.Column="1" Content="Show ACLog status" IsChecked="{Binding ShowAcLogStatus}" Margin="0,0,0,10" />
      <CheckBox Grid.Row="21" Grid.Column="1" Content="Show wfview status" IsChecked="{Binding ShowWfviewStatus}" Margin="0,0,0,10" />
      <CheckBox Grid.Row="22" Grid.Column="1" Content="Show radio frequency" IsChecked="{Binding ShowRadioFrequency}" Margin="0,0,0,10" />
      <CheckBox Grid.Row="23" Grid.Column="1" Content="Show mode and RF power" IsChecked="{Binding ShowModeAndRfPower}" Margin="0,0,0,10" />
      <CheckBox Grid.Row="24" Grid.Column="1" Content="Show last requested frequency" IsChecked="{Binding ShowLastRequestedFrequency}" Margin="0,0,0,10" />
      <CheckBox Grid.Row="25" Grid.Column="1" Content="Show last confirmed frequency" IsChecked="{Binding ShowLastConfirmedFrequency}" Margin="0,0,0,10" />
      <CheckBox Grid.Row="26" Grid.Column="1" Content="Show tune result" IsChecked="{Binding ShowTuneResult}" Margin="0,0,0,10" />
      <CheckBox Grid.Row="27" Grid.Column="1" Content="Expand station power panel by default" IsChecked="{Binding ExpandPowerPanel}" Margin="0,0,0,10" />
      <CheckBox Grid.Row="28" Grid.Column="1" Content="Use dark mode with red text" IsChecked="{Binding DarkModeEnabled}" Margin="0,0,0,10" />
    </Grid>
    </ScrollViewer>

    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="Cancel_Click" />
      <Button Content="Save" Width="90" Click="Save_Click" />
    </StackPanel>
  </Grid>
</Window>
