<Application x:Class="W3NTBPowerBridge.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F5F5F5" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#DADADA" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111827" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#444444" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#ABADB3" />
    <SolidColorBrush x:Key="OnAirIdleBackgroundBrush" Color="#F3F4F6" />
    <SolidColorBrush x:Key="OnAirIdleBorderBrush" Color="#D1D5DB" />
    <SolidColorBrush x:Key="OnAirIdleTextBrush" Color="#6B7280" />
    <SolidColorBrush x:Key="OnAirIdleLampBrush" Color="#9CA3AF" />
  </Application.Resources>
</Application>
